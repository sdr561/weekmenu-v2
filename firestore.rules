rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Gebruikersprofielen: alleen de gebruiker zelf
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Familiecodes: ingelogde gebruikers kunnen lezen (om te koppelen) en aanmaken
    match /familyCodes/{code} {
      allow read, create: if request.auth != null;
    }

    // Familie-document: alleen leden
    match /families/{familyId} {
      allow read: if request.auth != null &&
        request.auth.uid in resource.data.members;

      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.members;

      // Aanpassen: bestaand lid mag alles aanpassen;
      // niet-leden mogen zichzelf toevoegen (koppelen)
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.members ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']) &&
          request.resource.data.members.hasAll(resource.data.members) &&
          request.resource.data.members.hasAll([request.auth.uid]) &&
          request.resource.data.members.size() == resource.data.members.size() + 1
        )
      );
    }

    // Familie-subcollecties (gerechten, weekmenus, boodschappen): alleen leden
    match /families/{familyId}/{col}/{docId} {
      allow read, write: if request.auth != null &&
        request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.members;
    }
  }
}
